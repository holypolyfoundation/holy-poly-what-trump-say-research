[Unit]
Description=Holy-poly-what-trump-say-research: report Trump-say Polymarket research to Telegram
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=REPLACE_USER
Group=REPLACE_GROUP
WorkingDirectory=REPLACE_PROJECT_DIR
EnvironmentFile=REPLACE_PROJECT_DIR/.env
ExecStart=REPLACE_PROJECT_DIR/.venv/bin/python REPLACE_PROJECT_DIR/main.py
StandardOutput=journal
StandardError=journal
